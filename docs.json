{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dreamboard",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "docs/index",
              "docs/quickstart"
            ]
          },
          {
            "group": "Tutorials",
            "pages": [
              "docs/tutorials/building-your-first-game"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "docs/reference/cli",
              "docs/reference/dependency-setup",
              "docs/reference/rule-authoring",
              "docs/reference/manifest-authoring",
              "docs/reference/tiled-board-topology",
              "docs/reference/reducer",
              "docs/reference/ui-library",
              "docs/reference/testing"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/docs"
    },
    {
      "source": "/quickstart",
      "destination": "/docs/quickstart"
    },
    {
      "source": "/reference/cli",
      "destination": "/docs/reference/cli"
    },
    {
      "source": "/reference/dependency-setup",
      "destination": "/docs/reference/dependency-setup"
    },
    {
      "source": "/reference/manifest-authoring",
      "destination": "/docs/reference/manifest-authoring"
    },
    {
      "source": "/reference/rule-authoring",
      "destination": "/docs/reference/rule-authoring"
    },
    {
      "source": "/reference/reducer",
      "destination": "/docs/reference/reducer"
    },
    {
      "source": "/reference/tiled-board-topology",
      "destination": "/docs/reference/tiled-board-topology"
    },
    {
      "source": "/reference/game-interface",
      "destination": "/docs/reference/ui-library"
    },
    {
      "source": "/reference/ui-sdk",
      "destination": "/docs/reference/ui-library"
    },
    {
      "source": "/reference/testing",
      "destination": "/docs/reference/testing"
    },
    {
      "source": "/tutorials/building-your-first-game",
      "destination": "/docs/tutorials/building-your-first-game"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/dreamboard-games/dreamboard-cli"
      },
      {
        "label": "npm",
        "href": "https://www.npmjs.com/package/dreamboard"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dreamboard-games/dreamboard-cli"
    }
  }
}
