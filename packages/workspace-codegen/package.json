{
  "name": "@dreamboard/workspace-codegen",
  "version": "0.1.0",
  "description": "Internal Dreamboard workspace source generator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint 'src/**/*.ts'",
    "test": "bun test --timeout 30000",
    "test:unit": "bun test --timeout 30000"
  },
  "dependencies": {
    "@dreamboard/sdk-types": "workspace:*",
    "@dreamboard/ui-sdk": "workspace:*"
  },
  "devDependencies": {
    "@dreamboard/eslint-config": "workspace:*",
    "@dreamboard/typescript-config": "workspace:*",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.0",
    "typescript": "5.7.3"
  }
}
