{
  "name": "@dreamboard/api-client",
  "version": "0.1.0",
  "description": "Public Dreamboard API client and event types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client.gen": {
      "bun": "./src/client.gen.ts",
      "types": "./dist/client.gen.d.ts",
      "import": "./dist/client.gen.js"
    },
    "./types.gen": {
      "bun": "./src/types.gen.ts",
      "types": "./dist/types.gen.d.ts",
      "import": "./dist/types.gen.js"
    },
    "./react-query": {
      "bun": "./src/@tanstack/react-query.gen.ts",
      "types": "./dist/@tanstack/react-query.gen.d.ts",
      "import": "./dist/@tanstack/react-query.gen.js"
    },
    "./problem-types": {
      "bun": "./src/generated/problem-types.gen.ts",
      "types": "./dist/generated/problem-types.gen.d.ts",
      "import": "./dist/generated/problem-types.gen.js"
    },
    "./storage-paths": {
      "bun": "./src/storage-paths.ts",
      "types": "./dist/storage-paths.d.ts",
      "import": "./dist/storage-paths.js"
    },
    "./source-revisions": {
      "bun": "./src/source-revisions.ts",
      "types": "./dist/source-revisions.d.ts",
      "import": "./dist/source-revisions.js"
    },
    "./zod.gen": {
      "bun": "./src/zod.gen.ts",
      "types": "./dist/zod.gen.d.ts",
      "import": "./dist/zod.gen.js"
    }
  },
  "typesVersions": {
    "*": {
      "client.gen": [
        "./dist/client.gen.d.ts"
      ],
      "types.gen": [
        "./dist/types.gen.d.ts"
      ],
      "problem-types": [
        "./dist/generated/problem-types.gen.d.ts"
      ],
      "react-query": [
        "./dist/@tanstack/react-query.gen.d.ts"
      ],
      "storage-paths": [
        "./dist/storage-paths.d.ts"
      ],
      "source-revisions": [
        "./dist/source-revisions.d.ts"
      ],
      "zod.gen": [
        "./dist/zod.gen.d.ts"
      ]
    }
  },
  "scripts": {
    "sync:private-openapi": "bun run scripts/sync-private-openapi.ts",
    "build": "bun run scripts/generate.ts && tsc -b",
    "generate": "bun run scripts/generate.ts"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@tanstack/react-query": "^5.90.16",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dreamboard/typescript-config": "workspace:*",
    "@hey-api/openapi-ts": "^0.90.2"
  }
}
