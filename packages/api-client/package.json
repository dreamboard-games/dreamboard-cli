{
  "name": "@dreamboard/api-client",
  "version": "0.1.0",
  "description": "Public Dreamboard API client and event types",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client.gen": {
      "types": "./src/client.gen.ts",
      "import": "./src/client.gen.ts"
    },
    "./react-query": {
      "types": "./src/@tanstack/react-query.gen.ts",
      "import": "./src/@tanstack/react-query.gen.ts"
    },
    "./storage-paths": {
      "types": "./src/storage-paths.ts",
      "import": "./src/storage-paths.ts"
    },
    "./source-revisions": {
      "types": "./src/source-revisions.ts",
      "import": "./src/source-revisions.ts"
    }
  },
  "typesVersions": {
    "*": {
      "client.gen": [
        "./src/client.gen.ts"
      ],
      "react-query": [
        "./src/@tanstack/react-query.gen.ts"
      ],
      "storage-paths": [
        "./src/storage-paths.ts"
      ],
      "source-revisions": [
        "./src/source-revisions.ts"
      ]
    }
  },
  "scripts": {
    "sync:private-openapi": "bun run scripts/sync-private-openapi.ts",
    "build": "bun run scripts/generate.ts",
    "generate": "bun run scripts/generate.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.16"
  },
  "devDependencies": {
    "@dreamboard/typescript-config": "workspace:*",
    "@hey-api/openapi-ts": "^0.90.2"
  }
}
