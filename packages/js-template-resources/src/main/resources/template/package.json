{
  "name": "Demo Game",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "description": "A demo game project",
  "type": "module",
  "author": "Dreamboard",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint --cache ",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --cache --write \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.17",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsdown": "^0.11.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.1.3",
    "vitest-mock-extended": "^3.1.0"
  }
}
