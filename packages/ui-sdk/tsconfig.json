{
  "extends": "@dreamboard/typescript-config/base.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@dreamboard/manifest-contract": ["./manifest-contract"],
      "@dreamboard/ui-contract": ["./ui-contract-internal"],
      "@dreamboard/api-client": ["../../api-client/src/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__fixtures__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
