{
  "name": "@dreamboard/ui-sdk",
  "version": "0.0.40",
  "private": false,
  "description": "UI SDK for dreamboard plugin development",
  "type": "module",
  "//": "NOTE: main/types/exports point to SOURCE files (./src) NOT built files (./dist)",
  "//2": "This enables fast HMR during development. CI builds work because turbo builds dependencies first.",
  "//3": "DO NOT change these to ./dist/* - it breaks dev workflow requiring manual compilation on every change.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./reducer": {
      "types": "./src/reducer.ts",
      "import": "./src/reducer.ts"
    },
    "./internal/runtime-context": {
      "types": "./src/context/RuntimeContext.tsx",
      "import": "./src/context/RuntimeContext.tsx"
    },
    "./internal/usePluginRuntime": {
      "types": "./src/hooks/usePluginRuntime.ts",
      "import": "./src/hooks/usePluginRuntime.ts"
    },
    "./internal/createPluginRuntimeAPI": {
      "types": "./src/runtime/createPluginRuntimeAPI.ts",
      "import": "./src/runtime/createPluginRuntimeAPI.ts"
    },
    "./internal/useHandLayout": {
      "types": "./src/hooks/useHandLayout.ts",
      "import": "./src/hooks/useHandLayout.ts"
    },
    "./internal/usePanZoom": {
      "types": "./src/hooks/usePanZoom.ts",
      "import": "./src/hooks/usePanZoom.ts"
    },
    "./internal/useIsMobile": {
      "types": "./src/hooks/useIsMobile.ts",
      "import": "./src/hooks/useIsMobile.ts"
    },
    "./internal/player-state": {
      "types": "./src/types/player-state.ts",
      "import": "./src/types/player-state.ts"
    },
    "./internal/tiled-board": {
      "types": "./src/types/tiled-board.ts",
      "import": "./src/types/tiled-board.ts"
    },
    "./internal/plugin-state": {
      "types": "./src/types/plugin-state.ts",
      "import": "./src/types/plugin-state.ts"
    },
    "./types/runtime-api": {
      "types": "./src/types/runtime-api.ts",
      "import": "./src/types/runtime-api.ts"
    },
    "./plugin-styles.css": "./src/plugin-styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b && rollup -c rollup.config.js",
    "postbuild": "echo '✅ Generated ui-sdk.d.ts'",
    "dev": "cosmos",
    "cosmos": "cosmos",
    "cosmos:export": "cosmos-export",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@use-gesture/react": "^10.3.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "tailwindcss": "^4.1.5",
    "vaul": "^1.1.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@dreamboard/eslint-config": "workspace:*",
    "@dreamboard/tailwind-config": "workspace:*",
    "@dreamboard/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.34.0",
    "pem": "^1.14.8",
    "postcss": "^8.5.3",
    "react-cosmos": "^7.1.0",
    "react-cosmos-plugin-vite": "^7.1.0",
    "react-dom": "^19.2.0",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0",
    "react": "^19.0.0"
  }
}
