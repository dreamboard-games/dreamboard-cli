{
  "name": "@dreamboard/app-sdk",
  "version": "0.0.40",
  "description": "App authoring SDK for Dreamboard game logic",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./reducer": {
      "types": "./src/reducer.ts",
      "import": "./src/reducer.ts"
    },
    "./reducer/*": {
      "types": "./src/reducer/*.ts",
      "import": "./src/reducer/*.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "bun test"
  },
  "dependencies": {
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@dreamboard/eslint-config": "workspace:*",
    "@dreamboard/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^24.3.0",
    "eslint": "^9.39.0",
    "typescript": "^5.9.2"
  }
}
