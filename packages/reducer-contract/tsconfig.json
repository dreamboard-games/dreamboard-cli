{
  "extends": "@dreamboard/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": ".",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["src/**/*", "generated/**/*", "fixtures/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "build", "dist"]
}
