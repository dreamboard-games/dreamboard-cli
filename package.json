{
  "name": "dreamboard-cli-public",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --dir apps/dreamboard-cli run build",
    "stage:publish": "pnpm --dir apps/dreamboard-cli run stage:publish",
    "pack:publish": "pnpm --dir apps/dreamboard-cli run pack:publish",
    "verify:gh-auth": "pnpm --dir apps/dreamboard-cli run verify:gh-auth"
  }
}
