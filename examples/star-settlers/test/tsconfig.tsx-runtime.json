{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@dreamboard/manifest-contract": ["../shared/manifest-contract.ts"],
      "@dreamboard/ui-contract": ["../shared/generated/ui-contract.ts"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.d.ts",
    "../shared/**/*.ts",
    "../shared/**/*.d.ts"
  ]
}
