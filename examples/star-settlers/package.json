{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dreamboard dev",
    "typecheck": "tsc --noEmit -p manifest.tsconfig.json && tsc --noEmit -p app/tsconfig.json && tsc --noEmit -p ui/tsconfig.json",
    "typecheck:manifest": "tsc --noEmit -p manifest.tsconfig.json",
    "typecheck:app": "tsc --noEmit -p app/tsconfig.json",
    "typecheck:ui": "tsc --noEmit -p ui/tsconfig.json",
    "typecheck:test": "tsc --noEmit -p test/tsconfig.json",
    "test:ui": "tsx --tsconfig test/tsconfig.tsx-runtime.json --test test/ui/**/*.test.tsx"
  },
  "dependencies": {
    "@dreamboard/app-sdk": "workspace:*",
    "@dreamboard/ui-sdk": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.5",
    "@dreamboard/ui": "workspace:*"
  },
  "devDependencies": {
    "@dreamboard/sdk-types": "workspace:*",
    "@dreamboard/testing": "workspace:*",
    "@types/bun": "1.3.12",
    "@types/node": "^24.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "csstype": "^3.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.4.1"
}
