{
  "name": "dreamboard-cli",
  "version": "0.1.7",
  "description": "Design board games with AI and turn ideas into playable digital prototypes.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreamboard-games/dreamboard-cli.git"
  },
  "homepage": "http://dreamboard.games/",
  "bugs": {
    "url": "https://github.com/dreamboard-games/dreamboard-cli/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "dreamboard",
    "cli",
    "game-dev",
    "board-game",
    "multiplayer"
  ],
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "dreamboard": "dist/index.js"
  },
  "scripts": {
    "check:embedded-harness": "bun run scripts/check-embedded-harness.ts",
    "copy:static-scaffold-assets": "tsx scripts/copy-static-scaffold-assets.ts",
    "dev": "$HOME/.bun/bin/bun run scripts/dev.ts",
    "test": "bun run scripts/test.ts",
    "gen:props-docs": "tsx scripts/generate-props-docs.ts",
    "sync:skill-docs": "tsx scripts/sync-skill-docs.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "build": "tsc -p tsconfig.build.json --noEmit && tsup && pnpm run copy:static-scaffold-assets",
    "build:published": "DREAMBOARD_BUILD_CHANNEL=published tsup && pnpm run copy:static-scaffold-assets",
    "stage:publish": "pnpm run sync:skill-docs && pnpm run build:published && tsx scripts/stage-publish.ts",
    "pack:publish": "pnpm run stage:publish && npm pack --dry-run .publish/package"
  },
  "dependencies": {
    "@dreamboard/api-client": "workspace:*",
    "@dreamboard/app-sdk": "workspace:*",
    "@dreamboard/sdk-types": "workspace:*",
    "@dreamboard/tailwind-config": "workspace:*",
    "@dreamboard/ui": "workspace:^",
    "@dreamboard/ui-sdk": "workspace:*",
    "@dreamboard/ui-host-runtime": "workspace:*",
    "@dreamboard/workspace-codegen": "workspace:*",
    "@supabase/supabase-js": "^2.94.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "citty": "^0.2.0",
    "consola": "^3.4.2",
    "esbuild": "^0.25.1",
    "lucide-react": "^1.0.1",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.3",
    "tailwindcss": "^4.1.5",
    "tw-animate-css": "^1.2.4",
    "vite": "^5.4.19",
    "zustand": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prettier": "^3.5.1",
    "prettier-plugin-sql": "^0.18.1",
    "playwright": "^1.50.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
