{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tsconfig.json",
        "package.json",
        ".env*"
      ],
      "outputs": ["dist/**"],
      "env": ["MODE", "NODE_ENV"]
    },
    "build:binary": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tsconfig.json",
        "package.json",
        ".env*"
      ],
      "outputs": ["dist/dreamboard"],
      "env": ["MODE", "NODE_ENV"]
    }
  }
}
