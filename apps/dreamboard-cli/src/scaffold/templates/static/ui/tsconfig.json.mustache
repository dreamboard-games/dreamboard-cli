{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@dreamboard/manifest": ["../shared/manifest.ts"],
      "@dreamboard/ui-args": ["../shared/ui-args.ts"],
      "@dreamboard/sdk/*": ["./sdk/*"],
      "@shared/*": ["../shared/*"],
      "@sdk/*": ["./sdk/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
