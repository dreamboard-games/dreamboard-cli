{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@dreamboard/manifest": ["../shared/manifest.ts"],
      "@dreamboard/ui-args": ["../shared/ui-args.ts"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.d.ts", "../shared/**/*.ts", "../shared/**/*.d.ts"],

  "exclude": ["node_modules", "dist"]
}
